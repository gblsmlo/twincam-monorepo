{
  "name": "twincam-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/infra/*"
  ],
  "scripts": {
    "build": "bun run --parallel --if-present --workspaces build",
    "build:api": "bun --filter @twincam/api build",
    "build:web": "bun --filter @twincam/web build",
    "commit": "cz",
    "db:generate": "bun --filter @twincam/infra-database db:generate",
    "db:migrate": "bun --filter @twincam/infra-database db:migrate",
    "db:push": "bun --filter @twincam/infra-database db:push",
    "db:seed": "bun --filter @twincam/infra-database db:seed",
    "db:studio": "bun --filter @twincam/infra-database db:studio",
    "dev": "bun run --parallel --if-present --workspaces dev",
    "dev:api": "bun --filter @twincam/api dev",
    "dev:web": "bun --filter @twincam/web dev",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "lint:staged": "biome check --staged --no-errors-on-unmatched --write .",
    "prepare": "husky",
    "storybook": "bun --filter @twincam/storybook storybook",
    "storybook:build": "bun --filter @twincam/storybook storybook:build",
    "storybook:test": "bun --filter @twincam/storybook storybook:test",
    "test": "bun run --parallel --if-present --workspaces test",
    "test:db:rls": "bun --filter @twincam/infra-database test:rls",
    "toolchain:check": "sh scripts/check-toolchain.sh",
    "typecheck": "bun run --parallel --if-present --workspaces typecheck"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@base-ui/react": "1.6.0",
    "@biomejs/biome": "2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@fontsource-variable/inter": "5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.4",
    "better-auth": "^1.6.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.4",
    "elysia": "^1.4.23",
    "geist": "1.7.2",
    "husky": "^9.1.7",
    "lucide-react": "1.21.0",
    "pino-pretty": "^13.1.3",
    "react": "19.1.1",
    "react-day-picker": "10.0.1",
    "react-dom": "19.1.1",
    "react-hook-form": "^7.62.0",
    "srvx": "^0.11.16",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.1.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  }
}
