{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@features/*": ["apps/web/src/features/*"],
      "@twincam/api/*": ["apps/api/src/*"],
      "@twincam/auth": ["packages/auth/src/index.ts"],
      "@twincam/auth/*": ["packages/auth/src/*"],
      "@twincam/core": ["packages/core/src/index.ts"],
      "@twincam/core/*": ["packages/core/src/*"],
      "@twincam/infra-database": ["packages/infra/database/src/index.ts"],
      "@twincam/infra-database/*": ["packages/infra/database/src/*"],
      "@twincam/infra-env": ["packages/infra/env/src/index.ts"],
      "@twincam/infra-env/*": ["packages/infra/env/src/*"],
      "@twincam/observability": ["packages/observability/src/index.ts"],
      "@twincam/observability/*": ["packages/observability/src/*"],
      "@twincam/ui": ["packages/ui/src/index.ts"],
      "@twincam/ui/*": ["packages/ui/src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["bun"]
  }
}
