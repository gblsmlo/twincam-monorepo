{
  "name": "@twincam/infra-database",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "bun --env-file=../../../.env drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun --env-file=../../../.env drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "bun --env-file=../../../.env drizzle-kit push --config drizzle.config.ts",
    "db:seed": "bun --env-file=../../../.env src/seed.ts",
    "db:studio": "bun --env-file=../../../.env drizzle-kit studio --config drizzle.config.ts --host 0.0.0.0",
    "dev": "docker compose up -d postgres",
    "dev:db:down": "docker compose stop postgres",
    "typecheck": "tsc -p tsconfig.json"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schemas/users": "./src/schemas/users.ts",
    "./schema": "./src/schema.ts",
    "./workspace": "./src/workspace.ts"
  },
  "dependencies": {
    "@twincam/infra-env": "workspace:*",
    "@twincam/observability": "workspace:*",
    "drizzle-orm": "^0.44.4",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.13.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}
